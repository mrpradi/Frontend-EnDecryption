<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192E"
    tools:context=".HelpFaqActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_baseline_arrow_back_24"
                android:drawablePadding="8dp"
                android:text="Back"
                android:textColor="#00C89C"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Help &amp; FAQ"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find answers to common questions"
                android:textColor="#00C89C"
                android:textSize="16sp" />

            <!-- ABOUT THE APP -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="ABOUT THE APP"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_dark"
                android:orientation="vertical">

                <include
                    android:id="@+id/faq_secure_system"
                    layout="@layout/item_faq_expandable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2D3748" />

                <include
                    android:id="@+id/faq_who_is_it_for"
                    layout="@layout/item_faq_expandable" />
            </LinearLayout>

            <!-- USING THE APP -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="USING THE APP"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_dark"
                android:orientation="vertical">

                <include
                    android:id="@+id/faq_how_encryption_works"
                    layout="@layout/item_faq_expandable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2D3748" />

                <include
                    android:id="@+id/faq_decryption_fail"
                    layout="@layout/item_faq_expandable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2D3748" />

                <include
                    android:id="@+id/faq_file_storage"
                    layout="@layout/item_faq_expandable" />
            </LinearLayout>

            <!-- SECURITY & KEYS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="SECURITY &amp; KEYS"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_dark"
                android:orientation="vertical">

                <include
                    android:id="@+id/faq_lost_key"
                    layout="@layout/item_faq_expandable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2D3748" />

                <include
                    android:id="@+id/faq_tamper_detection"
                    layout="@layout/item_faq_expandable" />
            </LinearLayout>

            <!-- PRIVACY & DATA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PRIVACY &amp; DATA"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_dark"
                android:orientation="vertical">

                <include
                    android:id="@+id/faq_data_shared"
                    layout="@layout/item_faq_expandable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2D3748" />

                <include
                    android:id="@+id/faq_delete_data"
                    layout="@layout/item_faq_expandable" />
            </LinearLayout>

            <!-- Quick Assistance Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_protected_mode"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_shield"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Need Quick Assistance?"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Browse the FAQs above to quickly resolve common encryption, decryption, and security questions."
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/open_security_guide_button"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/button_save_changes_background"
                        android:text="Open Security Guide"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        app:backgroundTint="@null" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>