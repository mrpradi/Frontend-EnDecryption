<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_rounded_dark"
    android:padding="16dp">

    <ImageView
        android:id="@+id/icon_activity"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/file_icon_background"
        android:padding="8dp"
        android:src="@drawable/ic_history"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/title_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/value_text"
        app:layout_constraintStart_toEndOf="@id/icon_activity"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Encrypted: secret_doc.pdf" />

    <TextView
        android:id="@+id/value_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#00C89C"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Jan 24, 2026" />

    <TextView
        android:id="@+id/subtitle_history"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Operation successful"
        android:textColor="#A0AEC0"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/value_text"
        app:layout_constraintStart_toStartOf="@+id/title_text"
        app:layout_constraintTop_toBottomOf="@+id/title_text" />

</androidx.constraintlayout.widget.ConstraintLayout>