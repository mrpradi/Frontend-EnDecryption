<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the AppSettings shared preferences file from backup, as it contains device-specific settings. -->
        <exclude domain="sharedpref" path="AppSettings.xml"/>
    </cloud-backup>
    <!--
    <device-transfer>
        <include .../>
        <exclude .../>
    </device-transfer>
    -->
</data-extraction-rules>